
# configure key keybindings
# bindkey -e                                        # emacs key bindings
bindkey -v                                        # vim key bindings
bindkey -M viins 'jj' vi-cmd-mode                 # Bind ESC to 'jj'

# ls aliases
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'

# Theme Selector
alias themes="ls ~/.config/alacritty/themes/themes | fzf | xargs -I {} ln -sf ~/.config/alacritty/themes/themes/{} ~/.config/alacritty/current_theme.toml && echo "@@@" >> ~/.config/alacritty/alacritty.toml && sed -i '/@@@/d' ~/.config/alacritty/alacritty.toml"

# clear
alias c='clear'

# Copy to clipboad
alias yank='xclip -sel clip'
